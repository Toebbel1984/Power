Func Tweaks()
	RegWrite('HKCU\Control Panel\Desktop', 'AutoEndTasks','REG_SZ','1')
	RegWrite('HKCU\Control Panel\Desktop', 'HungAppTimeout','REG_SZ','100')
	RegWrite('HKCU\Control Panel\Desktop', 'WaitToKillAppTimeout','REG_SZ','100')
	RegWrite('HKCU\Control Panel\Desktop', 'WaitToKillServiceTimeout','REG_SZ','100')
	RegWrite('HKLM\SYSTEM\ControlSet002\Control', 'AutoEndTasks','REG_SZ','1')
	RegWrite('HKLM\SYSTEM\ControlSet002\Control', 'HungAppTimeout','REG_SZ','100')
	RegWrite('HKLM\SYSTEM\ControlSet002\Control', 'WaitToKillAppTimeout','REG_SZ','100')
	RegWrite('HKLM\SYSTEM\ControlSet002\Control', 'WaitToKillServiceTimeout','REG_SZ','100')
	RegWrite('HKLM\SYSTEM\CurrentControlSet\Control', 'AutoEndTasks','REG_SZ','1')
	RegWrite('HKLM\SYSTEM\CurrentControlSet\Control', 'HungAppTimeout','REG_SZ','100')
	RegWrite('HKLM\SYSTEM\CurrentControlSet\Control', 'WaitToKillAppTimeout','REG_SZ','100')
	RegWrite('HKLM\SYSTEM\CurrentControlSet\Control', 'WaitToKillServiceTimeout','REG_SZ','100')
EndFunc