Global Const $iMargin = 4
Global Const $iGUIMinX = 422, $iGUIMinY = 611, $iGUIMaxX = 422, $iGUIMaxY = 611
Global $MonitorIsOff = False

Global $HWND = WinGetHandle("classname=Progman")
$Struct = DllStructCreate("int cxLeftWidth;int cxRightWidth;int cyTopHeight;int cyBottomHeight;")
$sStruct = DllStructCreate("dword;int;ptr;int")
Global $numberOfAppInstances = ProcessList(_ProcessGetName(@AutoItPID))
For $i = 1 To $numberOfAppInstances[0][0]
	If $numberOfAppInstances[$i][1] <> @AutoItPID Then
		ProcessClose($numberOfAppInstances[$i][1])
		Exit
	EndIf
Next

Tweaks()

If $CMDLINE[0] > 0 Then
	For $i = 1 To $CMDLINE[0]
		If StringInStr(StringLower($CMDLINE[$i]), "reboot") Or StringInStr(StringLower($CMDLINE[$i]), "restart") Then
			Shutdown(6)
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "dialog") Then
			Dim $ObjShell
			$ObjShell = ObjCreate("Shell.Application")
			$ObjShell.ShutdownWindows()
			$ObjShell = ""
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "shutdown") Then
			Shutdown(5)
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "option") Then
			ShellExecute(@TempDir & "\shutdown.exe", "/r /o /t 0 /f", "", "runas", @SW_HIDE)
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "monoff") Then
			ShellExecute(@TempDir & '\MonitorOff_x64.exe', "/OFF /M", "", "runas", @SW_HIDE)
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "lock") Then
			ShellExecute("rundll32.exe", 'user32.dll,LockWorkStation')
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "safe") Then
			ShellExecute(@TempDir & "\safemode.exe", "/BootMenu:Off /F8StartupKey:Off /Minimal /Silent /Reboot", "", "runas", @SW_HIDE)
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "logoff") Then
			Shutdown(4)
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "bios") Then
			ShellExecute(@TempDir & "\shutdown.exe", "/r /fw /t 0 /f", "", "runas", @SW_HIDE)
			Bye2()
		ElseIf StringInStr(StringLower($CMDLINE[$i]), "trouble") Then
			ShellExecute(@TempDir & "\safemode.exe", "/BootMenu:On /F8StartupKey:On /Troubleshoot /Silent /Reboot", "", "runas", @SW_HIDE)
			Bye2()
		Else
			MsgBox(BitOR($MB_ICONQUESTION, $MB_SETFOREGROUND, $MB_DEFAULT_DESKTOP_ONLY, $MB_TOPMOST, $MB_SERVICE_NOTIFICATION, $MB_SYSTEMMODAL), "Power", "Arguments:" & @CRLF & @CRLF & "reboot / shutdown / lock / monoff / safeboot / logoff / bios / trouble")
			Bye2()
		EndIf
	Next
Else
	DoGUI()
EndIf

Func DoGUI()
	Global $BlackScreen = GUICreate("",@DesktopWidth,@DesktopHeight,0,0,$WS_POPUP)
	GUISetBkColor(0x000000)
	DllCall("user32.dll", "int", "AnimateWindow", "hwnd", $BlackScreen, "int", 1000, "long", 0x00080000)
	GUISetState(@SW_SHOW, $BlackScreen)
	Global $Form = GUICreate("", 422, 611, -1, -1, $WS_POPUP, BitOR($WS_EX_TOPMOST,$WS_EX_WINDOWEDGE))
	GUISetBkColor(0x000000)
	Global $Power = GUICtrlCreatePic("", 60, 30, 300, 58)
	_GUICtrl_OnHoverRegister($Power, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($Power, @TempDir & '\Shutdown.png')
	GUICtrlSetTip($Power, "Shutdown System!")
	Global $Reboot = GUICtrlCreatePic("", 60, 110, 300, 58)
	_GUICtrl_OnHoverRegister($Reboot, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($Reboot, @TempDir & '\Restart.png')
	GUICtrlSetTip($Reboot, "Restart System!")
	Global $Monitor = GUICtrlCreatePic("", 60, 190, 300, 58)
	_GUICtrl_OnHoverRegister($Monitor, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($Monitor, @TempDir & '\Monitor_off.png')
	GUICtrlSetTip($Monitor, "Turns of your Monitor!")
	Global $Lock = GUICtrlCreatePic("", 60, 271, 300, 58)
	_GUICtrl_OnHoverRegister($Lock, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($Lock, @TempDir & '\Lock.png')
	GUICtrlSetTip($Lock, "Lock's Workstation!")
	Global $Logoff = GUICtrlCreatePic("", 60, 351, 300, 58)
	_GUICtrl_OnHoverRegister($Logoff, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($Logoff, @TempDir & '\Logoff.png')
	GUICtrlSetTip($Logoff, "Logoff Current User!")
	Global $BIOS = GUICtrlCreatePic("", 60, 432, 300, 58)
	_GUICtrl_OnHoverRegister($BIOS, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($BIOS, @TempDir & '\BIOS_Boot.png')
	GUICtrlSetTip($BIOS, "Reboot into BIOS!")
	Global $line = GUICtrlCreateGraphic(45, 512, 330, 5)
	GUICtrlSetColor(-1, 0xFFFFFF)
	GUICtrlSetGraphic(-1, $GUI_GR_COLOR, 0xFFFFFF, 0xFFFFFF)
	GUICtrlSetGraphic(-1, $GUI_GR_RECT, 0, 0, 330, 5)
	Global $Trouble = GUICtrlCreatePic("", 72, 530, 57, 58)
	_GUICtrl_OnHoverRegister($Trouble, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($Trouble, @TempDir & '\Troubleshoot.png')
	GUICtrlSetTip($Trouble, "Reboot with troubleshoot option!")
	Global $MyExit = GUICtrlCreatePic("", 182, 530, 57, 58)
	_GUICtrl_OnHoverRegister($MyExit, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($MyExit, @TempDir & '\Exit.png')
	GUICtrlSetTip($MyExit, "Exit")
	Global $Safe = GUICtrlCreatePic("", 292, 530, 57, 58)
	_GUICtrl_OnHoverRegister($Safe, "_SetHover", "_SetLeave")
	_GuiCtrlSetImageEx($Safe, @TempDir & '\Safe_boot.png')
	GUICtrlSetTip($Safe, "Reboot into Safe Mode!")
	_GUICtrlCreateBorder(0, 0, 422, 611, 5)
	GUISetState(@SW_SHOW, $Form)
	
	GUIRegisterMsg($WM_LBUTTONDOWN, "_WM_LBUTTONDOWN")
	GUIRegisterMsg($WM_GETMINMAXINFO, "_WM_GETMINMAXINFO")

	While 1
		$nMsg = GUIGetMsg()
		Select
			Case $nMsg = $GUI_EVENT_CLOSE
				Bye1()
			Case $nMsg = $Power
				Shutdown(5)
				Bye1()
			Case $nMsg = $Reboot
				Shutdown(6)
				Bye1()
			Case $nMsg = $Monitor
				ShellExecute(@TempDir & '\MonitorOff_x64.exe', "/OFF /M", "", "runas", @SW_HIDE)
				Bye1()
			Case $nMsg = $Lock
				ShellExecute("rundll32.exe", 'user32.dll,LockWorkStation')
				Bye1()
			Case $nMsg = $Trouble
				ShellExecuteWait(@TempDir & "\safemode.exe", "/BootMenu:On /F8StartupKey:On /Troubleshoot /Silent /Reboot", "", "runas", @SW_HIDE)
				Bye1()
			Case $nMsg = $BIOS
				ShellExecuteWait(@TempDir & "\shutdown.exe", "/r /fw /t 0 /f", "", "runas", @SW_HIDE)
				Bye1()
			Case $nMsg = $Logoff
				Shutdown(4)
				Bye1()
			Case $nMsg = $MyExit
				Bye1()
			Case $nMsg = $Safe
				ShellExecuteWait(@TempDir & "\safemode.exe", "/BootMenu:Off /F8StartupKey:Off /Minimal /Silent /Reboot", "", "runas", @SW_HIDE)
				Bye1()
		EndSelect
	WEnd
EndFunc

Func _SetHover($iCtrlID, $iParam)
	Switch $iCtrlID
		Case $Power
			_GuiCtrlSetImageEx($Power, @TempDir & '\Shutdown_h.png')
		Case $Reboot
			_GuiCtrlSetImageEx($Reboot, @TempDir & '\Restart_h.png')
		Case $Monitor
			_GuiCtrlSetImageEx($Monitor, @TempDir & '\Monitor_off_h.png')
		Case $Lock
			_GuiCtrlSetImageEx($Lock, @TempDir & '\Lock_h.png')
		Case $Trouble
			_GuiCtrlSetImageEx($Trouble, @TempDir & '\Troubleshoot_h.png')
		Case $MyExit
			_GuiCtrlSetImageEx($MyExit, @TempDir & '\Exit_h.png')
		Case $Safe
			_GuiCtrlSetImageEx($Safe, @TempDir & '\Safe_boot_h.png')
		Case $LogOff
			_GuiCtrlSetImageEx($LogOff, @TempDir & '\Logoff_h.png')
		Case $BIOS
			_GuiCtrlSetImageEx($BIOS, @TempDir & '\BIOS_Boot_h.png')
	EndSwitch
EndFunc
Func _SetLeave($iCtrlID, $iParam)
	Switch $iCtrlID
		Case $Power
			_GuiCtrlSetImageEx($Power, @TempDir & '\Shutdown.png')
		Case $Reboot
			_GuiCtrlSetImageEx($Reboot, @TempDir & '\Restart.png')
		Case $Monitor
			_GuiCtrlSetImageEx($Monitor, @TempDir & '\Monitor_off.png')
		Case $Lock
			_GuiCtrlSetImageEx($Lock, @TempDir & '\Lock.png')
		Case $Trouble
			_GuiCtrlSetImageEx($Trouble, @TempDir & '\Troubleshoot.png')
		Case $MyExit
			_GuiCtrlSetImageEx($MyExit, @TempDir & '\Exit.png')
		Case $Safe
			_GuiCtrlSetImageEx($Safe, @TempDir & '\Safe_boot.png')
		Case $LogOff
			_GuiCtrlSetImageEx($LogOff, @TempDir & '\Logoff.png')
		Case $BIOS
			_GuiCtrlSetImageEx($BIOS, @TempDir & '\BIOS_Boot.png')
	EndSwitch
EndFunc

Func Bye2()
	FileDelete(@TempDir & '\*.png')
	FileDelete(@TempDir & '\shutdown.exe')
	FileDelete(@TempDir & '\safemode.ini')
	FileDelete(@TempDir & '\safemode.exe')
	FileDelete(@TempDir & '\MonitorOff_x64.exe')
	FileDelete(@TempDir & '\MonitorOff.ini')
	Exit
EndFunc

Func Bye1()
	GUISetState(@SW_HIDE, $Form)
	DllCall("user32.dll", "int", "AnimateWindow", "hwnd", $BlackScreen, "int", 2000, "long", 0x00090000)
	FileDelete(@TempDir & '\*.png')
	FileDelete(@TempDir & '\shutdown.exe')
	FileDelete(@TempDir & '\safemode.ini')
	FileDelete(@TempDir & '\safemode.exe')
	FileDelete(@TempDir & '\MonitorOff_x64.exe')
	FileDelete(@TempDir & '\MonitorOff.ini')
	Exit
EndFunc

Func _GUICtrlCreateBorder($iLeft, $iTop, $iWidth, $iHeight, $Line)
    Local $aLabel[5]
    $aLabel[0] = 4
    $aLabel[1] = GUICtrlCreateLabel("", $iLeft, $iTop, $Line, $iHeight)
    $aLabel[2] = GUICtrlCreateLabel("", $iLeft, $iTop, $iWidth, $Line)
    $aLabel[3] = GUICtrlCreateLabel("", $iLeft + $iWidth - $Line, $iTop, $Line, $iHeight)
    $aLabel[4] = GUICtrlCreateLabel("", $iLeft, $iTop + $iHeight - $Line, $iWidth, $Line)
    For $i = 1 To $aLabel[0]
        GUICtrlSetBkColor($aLabel[$i], 0xFFFFFF)
    Next
    Return $aLabel
EndFunc

Func _WM_LBUTTONDOWN($hWnd, $iMsg, $wParam, $lParam)
	Local $iCursorType = _GetBorder()
	If $iCursorType > 0 Then
		$iResizeType = 0xF000 + $iCursorType
		_SendMessage($Form, $WM_SYSCOMMAND, $iResizeType, 0)
	Else
		Local $aCurInfo = GUIGetCursorInfo($Form)
		If $aCurInfo[4] = 0 Then
			DllCall("user32.dll", "int", "ReleaseCapture")
			_SendMessage($Form, $WM_NCLBUTTONDOWN, $HTCAPTION, 0)
		EndIf
	EndIf
EndFunc   ;==>_WM_LBUTTONDOWN

Func _GetBorder()
	Local $aMPos = MouseGetPos()
	Local $aWinPos = WinGetPos($Form)
	Local $iSide = 0
	Local $iTopBot = 0
	If $aMPos[0] < $aWinPos[0] + $iMargin Then $iSide = 1
	If $aMPos[0] > $aWinPos[0] + $aWinPos[2] - $iMargin Then $iSide = 2
	If $aMPos[1] < $aWinPos[1] + $iMargin Then $iTopBot = 3
	If $aMPos[1] > $aWinPos[1] + $aWinPos[3] - $iMargin Then $iTopBot = 6
	Return $iSide + $iTopBot
EndFunc   ;==>_GetBorder

Func _WM_GETMINMAXINFO($hWnd, $iMsg, $wParam, $lParam)
	$tMinMaxInfo = DllStructCreate("int;int;int;int;int;int;int;int;int;int", $lParam)
	DllStructSetData($tMinMaxInfo, 7, $iGUIMinX)
	DllStructSetData($tMinMaxInfo, 8, $iGUIMinY)
	DllStructSetData($tMinMaxInfo, 9, $iGUIMaxX)
	DllStructSetData($tMinMaxInfo, 10, $iGUIMaxY)
	Return 0
EndFunc

